{
  "expo": {
    "name": "RankYatra",
    "slug": "rankyatra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rankyatra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.niskutech.rankyatra"
    },
    "android": {
      "package": "com.niskutech.rankyatra",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rankyatra.niskutech.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "RankYatra needs access to your photos to let you add images to posts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#f97316",
          "defaultChannel": "default"
        }
      ],
      "expo-video",
      "@react-native-google-signin/google-signin",
      [
        "expo-media-library",
        {
          "photosPermission": "RankYatra needs access to your gallery to save receipt images.",
          "savePhotosPermission": "RankYatra needs permission to save receipt images to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d04d1db1-6f4b-4017-9271-e09a101e148c"
      }
    },
    "owner": "rankyatraofficial"
  }
}
